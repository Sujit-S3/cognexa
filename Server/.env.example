# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
MONGODB_ATLAS_URI=mongodb+srv://user:password@cluster.mongodb.net/nexus-ai

# Auth
SECRET_KEY=replace-with-a-random-64-character-secret-generated-for-this-deployment
JWT_EXPIRES_IN_SECONDS=86400

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Email (SMTP). Leave blank in development — emails are logged instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@nexus-ai.app

# Web push (VAPID). Leave blank to disable push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@nexus-ai.app

# Pluggable AI service layer. Leave AI_SERVICE_URL blank to use the built-in mock provider
# (safe no-op responses) instead of calling a real external ML service.
AI_SERVICE_URL=
AI_SERVICE_API_KEY=
