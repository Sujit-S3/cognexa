NODE_ENV=development
APP_ENV=development
PORT=4000
APP_VERSION=0.1.0
COMMIT_SHA=development
LOG_LEVEL=debug

MONGODB_ATLAS_URI=mongodb://localhost:27017/cognexa
SECRET_KEY=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=cognexa_refresh
# COOKIE_DOMAIN=.cognexa.app
COOKIE_SECURE=false

CLIENT_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_MAX=30
FEATURE_FLAGS=ai_tutor,certificates

# Required in staging/production for distributed rate limits and future queue/cache adapters.
REDIS_URL=redis://localhost:6379
REDIS_REQUIRED=false
REDIS_CONNECT_TIMEOUT_MS=5000

# Protect /metrics with a random 32+ character bearer token in staging/production.
METRICS_AUTH_TOKEN=

# Optional OpenTelemetry OTLP/HTTP trace export. Both values are required when enabled.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cognexa-server
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Optional transactional email
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=no-reply@cognexa.app

# Optional web push
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@cognexa.app

# Direct-to-Cloudinary signed uploads for course media. Secrets remain server-side.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=cognexa

# Server-to-server AI gateway. Never expose this key through a VITE_ variable.
# AI_SERVICE_URL=https://ai-gateway.internal.example.com
# AI_SERVICE_API_KEY=
# AI_HEALTHCHECK_URL=https://ai-gateway.internal.example.com/health
# STORAGE_HEALTHCHECK_URL=https://storage-health.internal.example.com/health
