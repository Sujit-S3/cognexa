APP_ENV=production
NODE_ENV=production
PORT=4000
APP_VERSION=SET_FROM_RELEASE
COMMIT_SHA=SET_FROM_RELEASE
LOG_LEVEL=info
MONGODB_ATLAS_URI=SET_IN_SECRET_MANAGER
SECRET_KEY=SET_IN_SECRET_MANAGER
CLIENT_URL=https://app.cognexa.app
CORS_ALLOWED_ORIGINS=https://app.cognexa.app
COOKIE_DOMAIN=.cognexa.app
COOKIE_SECURE=true
REDIS_URL=SET_IN_SECRET_MANAGER
REDIS_REQUIRED=true
METRICS_AUTH_TOKEN=SET_IN_SECRET_MANAGER
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=SET_IN_SECRET_MANAGER
